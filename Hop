-- Flick Logic
local function getCharacter()
    local char = player.Character or player.CharacterAdded:Wait()
    return char, char:WaitForChild("Humanoid"), char:WaitForChild("HumanoidRootPart")
end

local function nearWall(hrp)
    local params = RaycastParams.new()
    params.FilterDescendantsInstances = {hrp.Parent}
    params.FilterType = Enum.RaycastFilterType.Blacklist

    local directions = {
        hrp.CFrame.RightVector * WALL_DISTANCE,
        -hrp.CFrame.RightVector * WALL_DISTANCE,
        hrp.CFrame.LookVector * WALL_DISTANCE,
        -hrp.CFrame.LookVector * WALL_DISTANCE,
    }

    for _, dir in pairs(directions) do
        local result = workspace:Raycast(hrp.Position, dir, params)
        if result then
            local hit = result.Instance
            -- Ignore ladders and trusses
            if hit:IsA("TrussPart") then continue end
            local name = hit.Name:lower()
            if name:find("ladder") or name:find("truss") or name:find("climb") then
                continue
            end
            return true
        end
    end
    return false
end

local function getDirection(humanoid)
    local moveDir = humanoid.MoveDirection
    if moveDir.Magnitude < 0.1 then
        return math.random(0, 1) == 1 and 1 or -1
    end
    local camRight = camera.CFrame.RightVector
    local dot = moveDir:Dot(camRight)
    return dot > 0 and -1 or 1
end

local function doFlick(requireWall)
    if debounce then return end
    debounce = true

    local char, humanoid, hrp = getCharacter()

    if requireWall and not nearWall(hrp) then
        debounce = false
        return
    end

    statusLabel.Text = "🔄 Flicking!"
    statusLabel.TextColor3 = Color3.fromRGB(255, 200, 50)

    if jumpOnFlick then
        local v = hrp.AssemblyLinearVelocity
        hrp.AssemblyLinearVelocity = Vector3.new(v.X, 55, v.Z)
        humanoid.Jump = true
    end

    humanoid.AutoRotate = false

    local dir = getDirection(humanoid)
    local angle = dir * FLICK_ANGLE

    hrp.CFrame = hrp.CFrame * CFrame.Angles(0, math.rad(angle), 0)
    task.wait(0.08)
    hrp.CFrame = hrp.CFrame * CFrame.Angles(0, math.rad(-angle), 0)

    humanoid.AutoRotate = true

    statusLabel.Text = controlMode == "jump" and "Jump near a wall to flick" or "Press FLICK anywhere"
    statusLabel.TextColor3 = Color3.fromRGB(100, 200, 100)
    debounce = false
end

-- Inf Jump logic (jump mode only)
UserInputService.JumpRequest:Connect(function()
    if not flickEnabled then return end

    if infJump and controlMode == "jump" then
        local char, humanoid, hrp = getCharacter()
        local v = hrp.AssemblyLinearVelocity
        hrp.AssemblyLinearVelocity = Vector3.new(v.X, 55, v.Z)
        humanoid.Jump = true
    end

    if controlMode == "jump" then
        doFlick(true)
    end
end)

flickBtnUI.MouseButton1Click:Connect(function()
    doFlick(false)
end)
